{
  "expo": {
    "name": "知乎--",
    "slug": "ZhihuMinusMinus",
    "version": "0.0.14",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zhihu--",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.huamu013.ZhihuMinusMinus",
      "associatedDomains": [
        "applinks:www.zhihu.com",
        "applinks:zhuanlan.zhihu.com",
        "applinks:zhihu.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.huamu013.ZhihuMinusMinus",
      "permissions": ["REQUEST_INSTALL_PACKAGES"],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "www.zhihu.com", "pathPrefix": "/" },
            { "scheme": "https", "host": "zhihu.com", "pathPrefix": "/" },
            { "scheme": "https", "host": "zhuanlan.zhihu.com", "pathPrefix": "/" },
            { "scheme": "https", "host": "oia.zhihu.com", "pathPrefix": "/" },
            { "scheme": "https", "host": "video.zhihu.com", "pathPrefix": "/" },
            { "scheme": "http", "host": "www.zhihu.com", "pathPrefix": "/" },
            { "scheme": "http", "host": "zhihu.com", "pathPrefix": "/" },
            { "scheme": "http", "host": "zhuanlan.zhihu.com", "pathPrefix": "/" },
            { "scheme": "http", "host": "oia.zhihu.com", "pathPrefix": "/" },
            { "scheme": "http", "host": "video.zhihu.com", "pathPrefix": "/" },
            { "scheme": "zhihu" },
            { "scheme": "zhihu--" }
          ],
          "category": [ "BROWSABLE", "DEFAULT" ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "useLegacyPackaging": true
          }
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "huamumu",
          "project": "zhihuminusminus"
        }
      ],
      "expo-web-browser",
      "expo-sharing",
      "expo-file-system"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "releaseNotes": {
        "v0.0.13": [
          "ZSE 签名算法重构: 引入 zhi-purity 纯 JS 实现，全面替换旧版 JS/Rust 混合逻辑，彻底解决签名失败导致的 403 问题，提升 API 调用成功率。",
          "环境兼容性增强: 针对 React Native 环境优化加密核心，移除对 Node.js 原生模块的依赖。"
        ],
        "v0.0.12": [
          "基础稳定性优化: 修复了若干 UI 细节与已知的小概率崩溃问题。"
        ]
      },
      "status": "🏗️ 持续开发中 (v0.0.14) - 核心功能与基础架构迭代中",
      "lastUpdated": "2026-05-04",
      "eas": {
        "projectId": "faa0f061-50e6-4ec4-bb6f-accda0dbd24f"
      },
      "sentryDsn": "https://93a6099dd49b040d9c516485eb3c72f6@o4511051860672512.ingest.de.sentry.io/4511051866112080"
    }
  }
}