{
  "expo": {
    "name": "知乎--",
    "slug": "ZhihuMinusMinus",
    "version": "0.1.3",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "zhihu--",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/android-icon-monochrome.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.huamu013.ZhihuMinusMinus",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "splash": {
        "backgroundColor": "#ffffff",
        "dark": {
          "backgroundColor": "#121212",
          "image": "./assets/images/android-icon-monochrome.png"
        }
      }
    },
    "android": {
      "splash": {
        "backgroundColor": "#ffffff",
        "image": "./assets/images/android-icon-monochrome.png",
        "dark": {
          "backgroundColor": "#121212",
          "image": "./assets/images/android-icon-monochrome.png"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.huamu013.ZhihuMinusMinus",
      "permissions": [
        "REQUEST_INSTALL_PACKAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "www.zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "zhuanlan.zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "oia.zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "video.zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "http",
              "host": "www.zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "http",
              "host": "zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "http",
              "host": "zhuanlan.zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "http",
              "host": "oia.zhihu.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "http",
              "host": "video.zhihu.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "zhihu"
            },
            {
              "scheme": "zhihu--"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "useLegacyPackaging": true
          }
        }
      ],
      "expo-web-browser",
      "expo-sharing",
      "expo-file-system",
      [
        "@sentry/react-native",
        {
          "organization": "huamumu",
          "project": "zhihuminusminus"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "sentryDsn": "https://93a6099dd49b040d9c516485eb3c72f6@o4511051860672512.ingest.de.sentry.io/4511051866112080",
      "releaseNotes": {
        "v0.1.1": [
          "全新主题自由定制配色系统: 新增以计算及主题钩子形式渲染的主题配色方案，允许在暗黑模式与明亮模式下跟随用户选择进行实时自适应变色。",
          "修复多处硬编码样式: 重构并统一了包括回答详情页、作者卡片、文章详情页、动态 Moments 页、搜索页面、我的关注页、收藏夹列表和 CollectionSelectorModal 中的知乎官方蓝色与静态收藏金色图标，全数收纳进动态主题色拦截引擎中。",
          "修复 CollectionSelectorModal 页面中 React 规则 Hooks 顺序调用报错导致崩溃的严重问题。"
        ],
        "v0.0.13": [
          "ZSE 签名算法重构: 引入 zhi-purity 纯 JS 实现，全面替换旧版 JS/Rust 混合逻辑，彻底解决签名失败导致的 403 问题，提升 API 调用成功率。",
          "环境兼容性增强: 针对 React Native 环境优化加密核心，移除对 Node.js 原生模块的依赖。"
        ],
        "v0.0.12": [
          "基础稳定性优化: 修复了若干 UI 细节与已知的小概率崩溃问题。"
        ]
      },
      "status": "🏗️ 持续开发中 (v0.1.3) - 核心功能与基础架构迭代中",
      "lastUpdated": "2026-06-30",
      "eas": {
        "projectId": "faa0f061-50e6-4ec4-bb6f-accda0dbd24f"
      }
    }
  }
}
